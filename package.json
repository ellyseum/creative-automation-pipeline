{
  "name": "creative-automation-pipeline",
  "version": "1.0.0",
  "description": "AI-powered creative automation pipeline for scalable social ad campaigns",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "pipeline": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/server.ts",
    "serve": "tsx src/server.ts",
    "pipeline": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:api": "vitest run e2e/api.test.ts",
    "test:azurite": "vitest run e2e/azurite.test.ts",
    "test:playwright": "npx playwright test",
    "test:all": "vitest run && vitest run e2e/api.test.ts && vitest run e2e/azurite.test.ts && npx playwright test",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'e2e/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'e2e/**/*.ts'",
    "prepare": "husky"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@google/genai": "^1.50.0",
    "@napi-rs/canvas": "^0.1.63",
    "commander": "^14.0.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "sharp": "^0.34.5",
    "yaml": "^2.8.0",
    "zod": "^4.3.0"
  },
  "optionalDependencies": {
    "@adobe/firefly-apis": "^2.0.0",
    "@adobe/firefly-services-common-apis": "^2.0.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.0"
  },
  "lint-staged": {
    "*.ts": ["prettier --write", "eslint --fix"]
  }
}
