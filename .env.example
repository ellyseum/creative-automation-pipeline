# --- GenAI Providers ---

# Google Gemini (default — covers LLM, vision, embeddings, and image generation)
GEMINI_API_KEY=

# Adobe Firefly (production target — requires enterprise IMS credentials)
# ADOBE_CLIENT_ID=
# ADOBE_CLIENT_SECRET=

# --- Provider Selection ---
# IMAGE_PROVIDER=gemini-image     # gemini-image (default, Nano Banana — supports reference images) | imagen (no ref support) | firefly | stub
# STORAGE_BACKEND=local           # local (default) | azure

# --- Azure Blob Storage (via Azurite for local dev) ---
# Run `docker-compose up -d` to start Azurite, then uncomment:
# STORAGE_BACKEND=azure
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

# --- Embedding ---
# EMBEDDING_DIMS=768              # 768 (default) | 1536 | 3072

# --- Server ---
# PORT=3000                       # Web server port (default: 3000)

# --- Model Override ---
# LLM_MODEL=gemini-2.5-flash      # Override default LLM (gemini-3.1-pro-preview)

# --- Debug ---
# LOG_LEVEL=debug                 # debug | info (default) | warn | error

# --- Concurrency / fan-out ---
# Process-wide caps on outbound API calls. These gate ALL pipeline runs in
# the current node process (important for the webserver, where multiple
# jobs run in parallel).
# LLM_CONCURRENCY=4               # max in-flight LLM / vision / embedding calls
# IMAGE_GEN_CONCURRENCY=2         # max in-flight image-gen calls (Imagen/Firefly)
#
# Per-run fan-out caps inside a single pipeline run.
# PRODUCT_CONCURRENCY=3           # products processed in parallel
# RATIO_CONCURRENCY=4             # aspect-ratio variants composed in parallel
# ASSET_ANALYZE_CONCURRENCY=4     # assets analyzed in parallel at index build
#
# Hero ReAct-loop retry budget. Each retry = one Imagen gen + one brand audit
# + one subject-preservation audit (~$0.04). Default 10 → worst-case ~$0.44
# per product when the audit never converges. Lower for budget-sensitive
# runs; higher for quality-sensitive runs.
# HERO_MAX_RETRIES=10
#
# Per-call timeout for outbound LLM requests (ms). Critical for preview
# models where the SDK can internally retry on 503 for minutes without
# surfacing. On timeout we throw a retryable error so the fallback chain
# advances to the next model. Default 90s per attempt.
# LLM_CALL_TIMEOUT_MS=90000
